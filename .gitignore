# ============================================================
# WhatsApp Privacy Blur - .gitignore
# ============================================================

# Project-specific: ignore the Pages folder
Pages/

# ============================================================
# OS-generated files
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================
# Editor / IDE files
# ============================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-workspace
*.sublime-project

# ============================================================
# Node / npm (if tooling is ever added)
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ============================================================
# Build output (if a build step is ever added)
# ============================================================
dist/
build/
out/
*.zip
*.crx
*.pem

# ============================================================
# Environment / secrets
# ============================================================
.env
.env.*
*.key
*.pem
