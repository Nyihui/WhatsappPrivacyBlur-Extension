{
  "manifest_version": 3,
  "name": "WhatsApp Privacy Blur",
  "version": "2.1.0",
  "author": "Nyihui",
  "description": "Premium real-time privacy filter for WhatsApp Web. Adds custom hover-to-reveal blur layers over names, numbers, profile pictures, previews, and chat bubbles.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "whatsapp-privacy-blur@extension",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "icons": {
    "16": "icons/logo-16.png",
    "32": "icons/logo-32.png",
    "48": "icons/logo-48.png",
    "128": "icons/logo-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/logo-32.png",
    "default_title": "WhatsApp Privacy Blur"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "selectors/index.js",
        "selectors/avatars.js",
        "selectors/names.js",
        "selectors/text.js",
        "selectors/previews.js",
        "selectors/input.js",
        "selectors/media-preview.js",
        "selectors/media-gallery.js",
        "selectors/misc.js",
        "content.js",
        "panel/styles.js",
        "panel/template.js",
        "panel/panel.js"
      ],
      "run_at": "document_start"
    }
  ]
}